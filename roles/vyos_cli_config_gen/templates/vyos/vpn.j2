set vpn openconnect authentication mode '{{ oc.authentication.mode }}'
{%         endif %}
{%         if (oc.authentication.local_users | default(none)) is gamersoutreach.vyos.vyos_defined(var_type="dict") %}
{%             for username, user in oc.authentication.local_users.items() %}
