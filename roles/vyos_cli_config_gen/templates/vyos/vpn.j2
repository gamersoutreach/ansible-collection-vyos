{%         endif %}
{%         if (ns.name_server | default(none)) is gamersoutreach.vyos.vyos_defined(var_type="list") %}
{%             for server in ns.name_server %}
set vpn openconnect network-settings name-server '{{ server }}'
{%             endfor %}
{%         endif %}
{%         if (ns.push_route | default(none)) is gamersoutreach.vyos.vyos_defined(var_type="list") %}
{%             for route in ns.push_route %}
set vpn openconnect network-settings push-route '{{ route }}'
{%             endfor %}
{%         endif %}
{%     endif %}
{%     if (oc.ssl | default(none)) is gamersoutreach.vyos.vyos_defined(var_type="dict") %}
{%         if (oc.ssl.ca_certificate | default(none)) is gamersoutreach.vyos.vyos_defined %}
set vpn openconnect ssl ca-certificate '{{ oc.ssl.ca_certificate }}'
{%         endif %}
{%         if (oc.ssl.certificate | default(none)) is gamersoutreach.vyos.vyos_defined %}
set vpn openconnect ssl certificate '{{ oc.ssl.certificate }}'
{%         endif %}
{%     endif %}
{% endif %}
