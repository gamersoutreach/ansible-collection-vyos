{%                 endif %}
{%             endfor %}
{%         endif %}
{%         if (oc.authentication.radius | default(none)) is gamersoutreach.vyos.vyos_defined(var_type="dict") %}
{%             if (oc.authentication.radius.server | default(none)) is gamersoutreach.vyos.vyos_defined(var_type="dict") %}
{%                 for server_addr, server in oc.authentication.radius.server.items() %}
