{%                 endif %}
{%                 if (rule_config.destination.group | default(none)) is gamersoutreach.vyos.vyos_defined %}
{%                     if (rule_config.destination.group.address_group | default(none)) is gamersoutreach.vyos.vyos_defined %}
set nat source rule {{ rule }} destination group address-group '{{ rule_config.destination.group.address_group }}'
{%                     endif %}
