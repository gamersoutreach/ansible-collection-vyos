{# source nat #}
{% if (nat.source | default(none)) is gamersoutreach.vyos.vyos_defined %}
{%     if (nat.source.rule | default(none)) is gamersoutreach.vyos.vyos_defined %}
{%         for rule, rule_config in nat.source.rule.items() %}
{%             if (rule_config.description | default(none)) is gamersoutreach.vyos.vyos_defined %}
set nat source rule {{ rule }} description '{{ rule_config.description }}'
{%             endif %}
{%             if (rule_config.disable | default(none)) is gamersoutreach.vyos.vyos_defined(true) %}
set nat source rule {{ rule }} disable
{%             endif %}
{%             if (rule_config.log | default(none)) is gamersoutreach.vyos.vyos_defined(true) %}
set nat source rule {{ rule }} log
{%             endif %}
{%             if (rule_config.exclude | default(none)) is gamersoutreach.vyos.vyos_defined(true) %}
set nat source rule {{ rule }} exclude
{%             endif %}
{%             if (rule_config.protocol | default(none)) is gamersoutreach.vyos.vyos_defined %}
set nat source rule {{ rule }} protocol '{{ rule_config.protocol }}'
{%             endif %}
{%             if (rule_config.outbound_interface | default(none)) is gamersoutreach.vyos.vyos_defined %}
{%                 if (rule_config.outbound_interface.name | default(none)) is gamersoutreach.vyos.vyos_defined %}
set nat source rule {{ rule }} outbound-interface name '{{ rule_config.outbound_interface.name }}'
{%                 endif %}
{%             endif %}
{%             if (rule_config.source | default(none)) is gamersoutreach.vyos.vyos_defined %}
{%                 if (rule_config.source.address | default(none)) is gamersoutreach.vyos.vyos_defined %}
set nat source rule {{ rule }} source address '{{ rule_config.source.address }}'
{%                 endif %}
{%                 if (rule_config.source.port | default(none)) is gamersoutreach.vyos.vyos_defined %}
set nat source rule {{ rule }} source port '{{ rule_config.source.port }}'
{%                 endif %}
{%                 if (rule_config.source.group | default(none)) is gamersoutreach.vyos.vyos_defined %}
{%                     if (rule_config.source.group.address_group | default(none)) is gamersoutreach.vyos.vyos_defined %}
set nat source rule {{ rule }} source group address-group '{{ rule_config.source.group.address_group }}'
{%                     endif %}
