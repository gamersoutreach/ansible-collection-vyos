set nat source rule {{ rule }} source group network-group '{{ rule_config.source.group.network_group }}'
{%                     endif %}
{%                     if (rule_config.source.group.port_group | default(none)) is gamersoutreach.vyos.vyos_defined %}
set nat source rule {{ rule }} source group port-group '{{ rule_config.source.group.port_group }}'
{%                     endif %}
{%                 endif %}
{%             endif %}
